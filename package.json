{
  "name": "mapleslog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run preflight:content && astro build",
    "preview": "astro preview",
    "serve": "python3 -m http.server ${PORT:-3003} --bind ${HOST:-0.0.0.0} --directory dist",
    "new:daily-post": "node scripts/new-daily-post.mjs",
    "preflight:content": "node scripts/preflight-content.mjs",
    "test:preflight": "node --test scripts/preflight-content.test.mjs scripts/new-daily-post.test.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/node": "^10.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.1",
    "sharp": "^0.34.3"
  }
}
