---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
  <div class="wrap">
    <div>
      <p class="title">{SITE_TITLE}</p>
      <p class="copy">Build logs, project notes, mistakes, fixes, and lessons worth keeping.</p>
    </div>
    <div class="meta">
      <p>© {today.getFullYear()} {SITE_AUTHOR}</p>
      <p>Built with Astro. Written in markdown. Mildly haunted.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding: 2rem 1rem 4rem;
    border-top: 1px solid rgba(var(--line), 0.18);
    background: rgba(var(--surface), 0.7);
    backdrop-filter: blur(12px);
  }
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem 2rem;
    color: rgb(var(--text-secondary));
    font-size: 0.95rem;
  }
  .title {
    margin: 0 0 0.4rem;
    color: rgb(var(--text-primary));
    font-weight: 700;
  }
  .copy, .meta p {
    margin: 0.2rem 0;
  }
</style>
