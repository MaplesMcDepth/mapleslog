---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const stacks = Array.from(new Set(projects.flatMap((project) => project.data.stack))).sort((a, b) => a.localeCompare(b));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Projects | Maples Log" description="Project pages and field notes for things being built." />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <p class="eyebrow">Projects</p>
        <h1>Projects that matter, not a graveyard of half-thoughts.</h1>
        <p class="section-copy">Browse by status, stack, and what actually looks worth your time.</p>
      </section>

      <section class="controls card">
        <label>
          Search
          <input id="project-search" type="search" placeholder="Search title, description, stack…" />
        </label>
        <label>
          Status
          <select id="project-status">
            <option value="all">All</option>
            <option value="active">Active</option>
            <option value="paused">Paused</option>
            <option value="shipped">Shipped</option>
          </select>
        </label>
        <label>
          Stack
          <select id="project-stack">
            <option value="all">All stacks</option>
            {stacks.map((stack) => <option value={stack.toLowerCase()}>{stack}</option>)}
          </select>
        </label>
      </section>

      <div class="results-meta">
        <p id="project-count">Showing {projects.length} projects</p>
      </div>

      <section class="grid-shell" id="project-grid">
        {projects.map((project) => (
          <a
            class="item card"
            href={`/projects/${project.id}/`}
            data-title={project.data.title.toLowerCase()}
            data-description={project.data.description.toLowerCase()}
            data-status={project.data.status}
            data-stack={project.data.stack.join(' ').toLowerCase()}
          >
            <div class="item-top">
              <p class="meta"><FormattedDate date={project.data.pubDate} /></p>
              <span class={`status-pill ${project.data.status}`}>{project.data.status}</span>
            </div>
            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>
            {project.data.stack.length > 0 && (
              <ul class="tag-list">
                {project.data.stack.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </a>
        ))}
      </section>
    </main>
    <Footer />

    <script is:inline>
      const search = document.getElementById('project-search');
      const status = document.getElementById('project-status');
      const stack = document.getElementById('project-stack');
      const count = document.getElementById('project-count');
      const items = Array.from(document.querySelectorAll('#project-grid .item'));

      const applyFilters = () => {
        const term = search?.value.toLowerCase().trim() || '';
        const currentStatus = status?.value || 'all';
        const currentStack = stack?.value || 'all';
        let visible = 0;

        items.forEach((item) => {
          const haystack = [
            item.dataset.title,
            item.dataset.description,
            item.dataset.stack,
          ].join(' ');
          const matchesSearch = !term || haystack.includes(term);
          const matchesStatus = currentStatus === 'all' || item.dataset.status === currentStatus;
          const matchesStack = currentStack === 'all' || (item.dataset.stack || '').includes(currentStack);
          const show = matchesSearch && matchesStatus && matchesStack;
          item.style.display = show ? '' : 'none';
          if (show) visible += 1;
        });

        if (count) count.textContent = `Showing ${visible} project${visible === 1 ? '' : 's'}`;
      };

      search?.addEventListener('input', applyFilters);
      status?.addEventListener('change', applyFilters);
      stack?.addEventListener('change', applyFilters);
    </script>
  </body>
</html>

<style>
  .controls {
    display: grid;
    grid-template-columns: 1.2fr 0.6fr 0.8fr;
    gap: 1rem;
    margin-top: 2rem;
  }
  .results-meta {
    margin-top: 0.9rem;
    color: rgb(var(--text-secondary));
    font-size: 0.95rem;
  }
  .controls label {
    display: grid;
    gap: 0.45rem;
    color: rgb(var(--text-primary));
    font-weight: 700;
  }
  .controls input,
  .controls select {
    border-radius: 1rem;
    border: 1px solid rgba(var(--line), 0.2);
    background: rgba(var(--surface-muted), 0.94);
    color: rgb(var(--text-primary));
    padding: 0.9rem 1rem;
  }
  .grid-shell {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .item {
    color: inherit;
    text-decoration: none;
  }
  .item-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .meta {
    color: rgb(var(--text-secondary));
    font-size: 0.92rem;
    text-transform: capitalize;
    margin: 0;
  }
  .status-pill {
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: capitalize;
    background: rgba(var(--surface-muted), 0.9);
  }
  .status-pill.active { color: #22c55e; }
  .status-pill.paused { color: #f59e0b; }
  .status-pill.shipped { color: #60a5fa; }
  @media (max-width: 980px) {
    .controls { grid-template-columns: 1fr; }
  }
  @media (max-width: 900px) {
    .controls,
    .grid-shell { grid-template-columns: 1fr; }
  }
</style>
