---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Projects | Maples Log" description="Project pages and field notes for things being built." />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <p class="eyebrow">Projects</p>
        <h1>Projects that matter, not a graveyard of half-thoughts.</h1>
        <p class="section-copy">The useful stuff: what exists, what it does, what stack it uses, and where the work is heading.</p>
      </section>

      <section class="list-shell">
        {projects.map((project) => (
          <a class="item card" href={`/projects/${project.id}/`}>
            <div>
              <p class="meta"><FormattedDate date={project.data.pubDate} /> · {project.data.status}</p>
              <h2>{project.data.title}</h2>
              <p>{project.data.description}</p>
            </div>
            {project.data.stack.length > 0 && (
              <ul class="tag-list">
                {project.data.stack.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .list-shell {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }
  .item {
    color: inherit;
    text-decoration: none;
  }
  .meta {
    color: rgb(var(--gray));
    font-size: 0.92rem;
    text-transform: capitalize;
  }
</style>
