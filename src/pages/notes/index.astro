---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Notes | Maples Log" description="Short notes, ideas, and snippets worth keeping." />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <p class="eyebrow">Notes</p>
        <h1>Short entries, useful scraps.</h1>
        <p class="section-copy">For things too small to become a full post but too useful to lose.</p>
      </section>

      <section class="list-shell">
        {notes.map((note) => (
          <a class="item card" href={`/notes/${note.id}/`}>
            <div>
              <p class="meta"><FormattedDate date={note.data.pubDate} /> · {note.data.kind}</p>
              <h2>{note.data.title}</h2>
              <p>{note.data.description}</p>
            </div>
            {note.data.tags.length > 0 && (
              <ul class="tag-list">
                {note.data.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .list-shell {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }
  .item {
    color: inherit;
    text-decoration: none;
  }
  .meta {
    color: rgb(var(--gray));
    font-size: 0.92rem;
    text-transform: capitalize;
  }
</style>
